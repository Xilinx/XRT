PACKAGE_NAME="xrt-aws"
PACKAGE_VERSION="@XRT_VERSION_STRING@"
MAKE[0]="cd driver/aws; make KERNELDIR=${kernel_source_dir}"
CLEAN="cd driver/aws; make clean KERNELDIR=${kernel_source_dir}"
BUILT_MODULE_NAME[0]="awsmgmt"
BUILT_MODULE_LOCATION[0]="driver/aws/mgmt"
DEST_MODULE_LOCATION[0]="/kernel/extras"
AUTOINSTALL="yes"
