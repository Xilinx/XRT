PACKAGE_NAME="xrt"
PACKAGE_VERSION="@XRT_VERSION_STRING@"
MAKE[0]="cd driver/xocl; make KERNEL_SRC=${kernel_source_dir}"
CLEAN="cd driver/xocl; make clean KERNEL_SRC=${kernel_source_dir}"
BUILD_EXCLUSIVE_CONFIG="CONFIG_DRM"
BUILT_MODULE_NAME[0]="xocl"
BUILT_MODULE_LOCATION[0]="driver/xocl/userpf"
DEST_MODULE_LOCATION[0]="/kernel/extras"
BUILT_MODULE_NAME[1]="xclmgmt"
BUILT_MODULE_LOCATION[1]="driver/xocl/mgmtpf"
DEST_MODULE_LOCATION[1]="/kernel/extras"
AUTOINSTALL="yes"
